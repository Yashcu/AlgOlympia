# ===== BACKEND ENVIRONMENT VARIABLES =====

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://algolympia.example.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/algolympia_db

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ===== OPTIONAL CONFIGURATIONS =====

# Database Connection Pool (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/algolympia_db?connection_limit=20

# Redis (when scaling to multiple servers)
# REDIS_URL=redis://localhost:6379

# Error Tracking (Sentry)
# SENTRY_DSN=https://key@sentry.io/project

# Metrics Collection
# PROMETHEUS_PORT=9090

# ===== DEVELOPMENT ONLY =====
# Uncomment for local development
# NODE_ENV=development
# PORT=5000
# FRONTEND_URL=http://localhost:5173
# DATABASE_URL=postgresql://postgres:password@localhost:5432/algolympia_dev
