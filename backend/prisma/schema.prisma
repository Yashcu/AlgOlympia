generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teams         Team[]       @relation("TeamLeader")
  memberships   TeamMember[]
  contestsOwned Contest[]    @relation("ContestCreator")

  @@index([clerkId])
  @@index([email])
}

model Team {
  id         String @id @default(uuid())
  name       String @unique
  inviteCode String @unique

  leaderId String
  leader   User   @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members   TeamMember[]
  createdAt DateTime     @default(now())
}

model TeamMember {
  id String @id @default(uuid())

  userId String
  teamId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])
}

model Contest {
  id        String        @id @default(cuid())
  title     String
  startTime DateTime
  endTime   DateTime
  status    ContestStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  createdById String
  createdBy   User   @relation("ContestCreator", fields: [createdById], references: [id])

  problems Problem[]

  @@index([createdById])
  @@index([status])
}

model Problem {
  id           String   @id @default(cuid())
  contestId    String
  title        String
  index        String
  description  String              // Problem statement (markdown + LaTeX)
  inputFormat  String?             // Input specification section
  outputFormat String?             // Output specification section
  notes        String?             // Additional notes / constraints
  timeLimit    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contest   Contest    @relation(fields: [contestId], references: [id], onDelete: Cascade)
  testcases Testcase[]

  @@unique([contestId, index])
  @@index([contestId])
}

model Testcase {
  id        String   @id @default(cuid())
  problemId String
  input     String
  output    String
  isHidden  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

enum ContestStatus {
  DRAFT
  UPCOMING
  RUNNING
  ENDED
}
